{
  "name": "game-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -C apps/platform dev",
    "build": "pnpm -C apps/platform build && node games/blackout/scripts/copy-db-assets.mjs",
    "start": "pnpm -C apps/platform start",
    "typecheck": "pnpm -C apps/platform typecheck",
    "test": "jest",
    "test:blackout": "jest --selectProjects blackout",
    "test:imposter": "jest --selectProjects imposter",
    "test:secret-signals": "jest --selectProjects secret-signals",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "pinia": "^3.0.2",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vue": "^3.5.16",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "diff": "^8.0.3",
    "esbuild": ">=0.25.0"
  }
}
