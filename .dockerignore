# Version control
.git

# Dependencies (reinstalled inside Docker)
node_modules
**/node_modules

# Build output (produced inside Docker)
apps/platform/dist

# Database files (re-seeded on first run)
**/*.sqlite
**/*.sqlite-wal
**/*.sqlite-shm

# Test artifacts
playwright-report
test-results

# Logs
*.log
npm-debug.log*

# Environment files
.env
.env.local
.env.*.local

# IDE / OS
.vscode
.idea
*.DS_Store
