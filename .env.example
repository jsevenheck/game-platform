# ── Server ───────────────────────────────────────────────────────────────────
# TCP port the Express server listens on (default: 3000)
PORT=3000

# Set to "production" in deployed environments
NODE_ENV=development

# ── Logging (Pino) ───────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
# Defaults: debug (dev), warn (test), info (production)
LOG_LEVEL=debug

# Pretty-print logs with pino-pretty (true = human-readable, false = JSON)
# Defaults: true (dev), false (test/production)
LOG_PRETTY=true

# Emit a debug log for every Socket.IO event (very verbose)
LOG_SOCKET_EVENTS=false

# ── Metrics (Prometheus) ─────────────────────────────────────────────────────
# Expose /metrics endpoint (default: true outside production, false in production)
METRICS_ENABLED=true

# Optional bearer token to protect /metrics scrapes.
# When set, requests must include:  Authorization: Bearer <token>
#                                or  x-metrics-token: <token>
# METRICS_AUTH_TOKEN=your-secret-token
